        <span style="color:#fff;font-weight:700;font-size:1rem;letter-spacing:.04em;font-family:var(--ff-body);">OMAXE</span>
      </div>
    </div>
    <div><div class="nav-logo-text">Super Corridor</div></div>
  </a>
  <ul class="nav-links">

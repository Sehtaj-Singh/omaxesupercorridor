<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Omaxe Super Corridor Indore | Premium Residential Plots</title>
<meta name="description" content="Omaxe Super Corridor Indore – 450-acre premium integrated township. Residential plots from 800–5000 sq ft at ₹2,800/sq ft. Book now." />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Source+Sans+3:wght@300;400;500;600&display=swap" rel="stylesheet" />
<style>
  :root {
    --blue:#1565c0;--blue-dark:#0d47a1;--blue-mid:#1976d2;--blue-light:#e3f0fb;
    --red:#d32f2f;--red-light:#ffebee;
    --gold:#c9a84c;--gold-light:#e0c070;
    --dark:#0a1628;--dark-mid:#112240;--dark-surface:#1a3a5c;
    --text:#f0f4f8;--text-muted:#9ab0c8;
    --border:rgba(21,101,192,0.25);--border-light:rgba(255,255,255,0.12);
    --ff-display:'Playfair Display',Georgia,serif;
    --ff-body:'Source Sans 3',sans-serif;
    --white:#ffffff;
  }
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
  html{scroll-behavior:smooth;}
  body{background:#f5f7fa;color:#1a2a3a;font-family:var(--ff-body);font-weight:400;line-height:1.7;overflow-x:hidden;}
  nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:.7rem 2.5rem;background:var(--white);box-shadow:0 2px 16px rgba(13,71,161,.13);gap:1rem;transition:padding .3s;}
  .nav-logo-wrap{display:flex;align-items:center;gap:.7rem;text-decoration:none;}
  .nav-logo-img{height:48px;width:auto;display:block;object-fit:contain;}
  .nav-logo-text{font-family:var(--ff-display);font-size:1rem;font-weight:600;color:var(--blue-dark);line-height:1.2;}
  .nav-links{display:flex;gap:1.4rem;list-style:none;}
  .nav-links a{color:#334;text-decoration:none;font-size:.82rem;letter-spacing:.04em;font-weight:500;transition:color .2s;padding:.3rem 0;border-bottom:2px solid transparent;}
  .nav-links a:hover{color:var(--blue);border-bottom-color:var(--blue);}
  .nav-right{display:flex;align-items:center;gap:.6rem;flex-shrink:0;}
  .lang-toggle{display:flex;border:1.5px solid var(--blue);border-radius:2px;overflow:hidden;}
  .lang-btn{background:none;border:none;padding:.3rem .65rem;font-family:var(--ff-body);font-size:.75rem;font-weight:600;color:var(--blue);cursor:pointer;transition:.2s;}
  .lang-btn.active{background:var(--blue);color:#fff;}
  .nav-cta{background:var(--red);color:#fff;border:none;padding:.55rem 1.3rem;font-family:var(--ff-body);font-size:.82rem;font-weight:600;letter-spacing:.05em;cursor:pointer;transition:.2s;text-decoration:none;white-space:nowrap;border-radius:2px;}
  .nav-cta:hover{background:var(--blue-dark);}
  .hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px;}
  .hamburger span{display:block;width:24px;height:2px;background:var(--blue-dark);}
  .hero{min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 4rem 5rem;position:relative;overflow:hidden;background:linear-gradient(150deg,var(--dark) 0%,var(--dark-mid) 50%,var(--blue-dark) 100%);}
  .hero-bg-pattern{position:absolute;inset:0;opacity:.05;background-image:repeating-linear-gradient(45deg,#fff 0,#fff 1px,transparent 0,transparent 50%);background-size:20px 20px;}
  .hero-accent{position:absolute;top:0;right:0;width:55%;height:100%;background:linear-gradient(135deg,transparent 30%,rgba(21,101,192,.18) 100%);pointer-events:none;}
  .hero-badge{display:inline-flex;align-items:center;gap:.6rem;background:rgba(211,47,47,.15);border:1px solid rgba(211,47,47,.4);padding:.45rem 1.1rem;font-size:.75rem;letter-spacing:.12em;text-transform:uppercase;color:#ff8080;margin-bottom:1.8rem;position:relative;}
  .hero-badge::before{content:'';display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--red);animation:pulse 2s infinite;}
  @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.4)}}
  .hero h1{font-family:var(--ff-display);font-size:clamp(2.4rem,5.5vw,4.8rem);font-weight:700;line-height:1.1;max-width:740px;color:var(--white);position:relative;}
  .hero h1 em{font-style:italic;color:var(--gold);}
  .hero-sub{max-width:540px;color:rgba(255,255,255,.75);font-size:1.05rem;margin-top:1.5rem;position:relative;line-height:1.8;}
  .hero-actions{display:flex;gap:1rem;flex-wrap:wrap;margin-top:2.5rem;position:relative;}
  .btn-primary{background:var(--red);color:#fff;border:none;padding:.9rem 2.2rem;font-family:var(--ff-body);font-size:.9rem;font-weight:600;letter-spacing:.06em;cursor:pointer;transition:.2s;text-decoration:none;display:inline-block;border-radius:2px;}
  .btn-primary:hover{background:#b71c1c;transform:translateY(-2px);box-shadow:0 6px 20px rgba(211,47,47,.35);}
  .btn-outline{background:transparent;color:#fff;border:2px solid rgba(255,255,255,.4);padding:.85rem 2.2rem;font-family:var(--ff-body);font-size:.9rem;font-weight:500;cursor:pointer;transition:.2s;text-decoration:none;display:inline-block;border-radius:2px;}
  .btn-outline:hover{border-color:var(--gold);color:var(--gold);}
  .hero-stats{display:flex;gap:3rem;flex-wrap:wrap;margin-top:4rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,.15);position:relative;}
  .hero-stat-num{font-family:var(--ff-display);font-size:2.2rem;font-weight:700;color:var(--gold);line-height:1;}
  .hero-stat-label{font-size:.73rem;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.55);margin-top:.3rem;}
  .scroll-indicator{position:absolute;right:4rem;bottom:4rem;display:flex;flex-direction:column;align-items:center;gap:.5rem;color:rgba(255,255,255,.4);font-size:.68rem;letter-spacing:.15em;text-transform:uppercase;}
  .scroll-line{width:1px;height:50px;background:linear-gradient(var(--gold),transparent);animation:scroll-anim 2s ease-in-out infinite;}
  @keyframes scroll-anim{0%{height:0;opacity:1}100%{height:50px;opacity:0}}
  .highlights{background:var(--blue);padding:3rem 4rem;}
  .highlights-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;}
  .highlight-item{text-align:center;padding:1rem;border-right:1px solid rgba(255,255,255,.15);}
  .highlight-item:last-child{border-right:none;}
  .highlight-num{font-family:var(--ff-display);font-size:2.6rem;font-weight:700;color:#fff;line-height:1;}
  .highlight-label{font-size:.76rem;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.65);margin-top:.4rem;}
  section{padding:6rem 4rem;}
  .section-label{font-size:.72rem;letter-spacing:.2em;text-transform:uppercase;color:var(--blue);font-weight:600;margin-bottom:.8rem;}
  .section-title{font-family:var(--ff-display);font-size:clamp(1.9rem,3.5vw,3rem);font-weight:700;line-height:1.2;max-width:640px;color:var(--dark-mid);}
  .section-title em{font-style:italic;color:var(--red);}
  .divider{width:56px;height:3px;background:linear-gradient(to right,var(--blue),var(--red));margin:1.4rem 0 2.5rem;border-radius:2px;}
  .section-light{background:#fff;}
  .about{background:#fff;}
  .about-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;margin-top:3rem;}
  .about-img-wrap{position:relative;aspect-ratio:4/5;background:linear-gradient(135deg,var(--blue-light),#ddeeff);border:2px solid var(--border);overflow:hidden;border-radius:4px;}
  .about-note{position:absolute;bottom:-1rem;right:-1rem;background:var(--blue);color:#fff;padding:1.2rem 1.5rem;z-index:3;font-weight:600;font-size:.95rem;line-height:1.4;border-radius:2px;box-shadow:0 8px 24px rgba(13,71,161,.25);}
  .about-content p{color:#445;margin-bottom:1.2rem;font-size:.97rem;line-height:1.8;}
  .about-features{display:grid;grid-template-columns:1fr 1fr;gap:.8rem;margin-top:2rem;}
  .about-feature{display:flex;align-items:center;gap:.75rem;font-size:.88rem;color:#334;font-weight:500;}
  .about-feature::before{content:'✔';color:var(--blue);font-size:.9rem;flex-shrink:0;}

  /* ══════════════════════════════════════
     AMENITIES — screenshot-matched style
     White cards · SVG line icons · 5 cols
  ══════════════════════════════════════ */
  .amenities{background:#f7f7f7;}
  .amenities-grid{
    display:grid;
    grid-template-columns:repeat(5,1fr);
    gap:18px;
    margin-top:2.5rem;
  }
  .amenity-card{
    background:#fff;
    border:1px solid #e4e4e4;
    border-radius:12px;
    padding:2.2rem 1rem 1.8rem;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:flex-start;
    gap:.9rem;
    text-align:center;
    transition:box-shadow .22s,border-color .22s,transform .22s;
    cursor:default;
  }
  .amenity-card:hover{
    box-shadow:0 8px 28px rgba(0,0,0,.08);
    border-color:#ccc;
    transform:translateY(-4px);
  }
  .amenity-icon-wrap{
    width:68px;height:68px;
    display:flex;align-items:center;justify-content:center;
  }
  .amenity-icon-wrap svg{
    width:60px;height:60px;
    stroke:#5a5a5a;
    fill:none;
    stroke-width:1.5;
    stroke-linecap:round;
    stroke-linejoin:round;
  }
  .amenity-name{
    font-size:.84rem;
    font-weight:400;
    color:#555;
    line-height:1.35;
    font-family:var(--ff-body);
  }

  /* Gallery */
  .gallery{background:var(--blue-light);}
  .gallery-tabs{display:flex;gap:0;margin-top:2.5rem;border-bottom:2px solid rgba(21,101,192,.15);flex-wrap:wrap;}
  .gallery-tab{padding:.75rem 1.8rem;font-size:.84rem;font-weight:600;cursor:pointer;border:none;background:transparent;color:#778;letter-spacing:.05em;transition:.2s;border-bottom:3px solid transparent;margin-bottom:-2px;}
  .gallery-tab.active{color:var(--blue);border-bottom-color:var(--blue);}
  .gallery-tab:hover:not(.active){color:var(--blue-mid);}
  .gallery-panel{display:none;margin-top:2rem;}
  .gallery-panel.active{display:block;}
  .gallery-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;}
  .gallery-item{position:relative;aspect-ratio:4/3;background:linear-gradient(135deg,#c8d8f0,#a8c0e8);border-radius:6px;overflow:hidden;cursor:pointer;transition:.3s;}
  .gallery-item:hover{transform:scale(1.02);box-shadow:0 12px 32px rgba(13,71,161,.2);}
  .gallery-item-inner{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.6rem;}
  .gallery-item-icon{font-size:2.5rem;opacity:.35;}
  .gallery-item-label{font-size:.78rem;letter-spacing:.08em;text-transform:uppercase;color:rgba(13,71,161,.6);font-weight:600;}
  .gallery-item-overlay{position:absolute;inset:0;background:linear-gradient(0deg,rgba(13,71,161,.6) 0%,transparent 60%);opacity:0;transition:.3s;}
  .gallery-item:hover .gallery-item-overlay{opacity:1;}
  .gallery-item-caption{position:absolute;bottom:0;left:0;right:0;padding:1rem;color:#fff;font-size:.82rem;font-weight:600;transform:translateY(100%);transition:.3s;}
  .gallery-item:hover .gallery-item-caption{transform:translateY(0);}
  .work-status{position:absolute;top:.75rem;right:.75rem;padding:.25rem .7rem;border-radius:20px;font-size:.68rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;}
  .status-active{background:#e8f5e9;color:#2e7d32;}
  .status-complete{background:#e3f2fd;color:#1565c0;}
  .cert-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;}
  .cert-card{background:#fff;border:1.5px solid rgba(21,101,192,.15);border-radius:6px;padding:1.8rem 1.2rem;text-align:center;transition:.3s;box-shadow:0 2px 8px rgba(13,71,161,.05);}
  .cert-card:hover{border-color:var(--blue);box-shadow:0 8px 24px rgba(13,71,161,.12);transform:translateY(-3px);}
  .cert-icon{font-size:2.5rem;margin-bottom:.8rem;}
  .cert-name{font-size:.88rem;font-weight:700;color:var(--dark-mid);margin-bottom:.3rem;}
  .cert-body{font-size:.75rem;color:#778;}
  .cert-badge{display:inline-block;margin-top:.8rem;background:var(--blue-light);color:var(--blue);font-size:.68rem;font-weight:700;padding:.2rem .65rem;border-radius:20px;letter-spacing:.05em;}
  /* Other projects */
  .other-projects{background:#fff;}
  .projects-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-top:3rem;}
  .project-card{border-radius:8px;overflow:hidden;border:1px solid rgba(21,101,192,.1);transition:.3s;box-shadow:0 2px 12px rgba(13,71,161,.06);}
  .project-card:hover{transform:translateY(-6px);box-shadow:0 16px 40px rgba(13,71,161,.15);}
  .project-card-img{height:220px;position:relative;overflow:hidden;}
  .project-card-img-bg{width:100%;height:100%;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:.6rem;transition:.3s;}
  .project-card:hover .project-card-img-bg{transform:scale(1.05);}
  .proj-city1{background:linear-gradient(135deg,#1a3a7a,#2563b0);}
  .proj-city2{background:linear-gradient(135deg,#7a1a2a,#b02545);}
  .proj-hills{background:linear-gradient(135deg,#1a5c3a,#2a8f5a);}
  .project-tag{position:absolute;top:1rem;left:1rem;background:rgba(255,255,255,.9);color:var(--dark-mid);font-size:.7rem;font-weight:700;padding:.3rem .75rem;border-radius:20px;letter-spacing:.05em;}
  .project-card-body{padding:1.8rem;}
  .project-name{font-family:var(--ff-display);font-size:1.3rem;font-weight:700;color:var(--dark-mid);margin-bottom:.3rem;}
  .project-location{font-size:.78rem;color:var(--blue);font-weight:600;letter-spacing:.05em;text-transform:uppercase;margin-bottom:.8rem;}
  .project-desc{font-size:.85rem;color:#556;line-height:1.7;margin-bottom:1rem;}
  .project-features{display:flex;flex-wrap:wrap;gap:.4rem;}
  .project-feature-tag{background:var(--blue-light);color:var(--blue);font-size:.7rem;font-weight:600;padding:.2rem .65rem;border-radius:20px;}
  .project-cta{display:inline-flex;align-items:center;gap:.4rem;margin-top:1.2rem;font-size:.82rem;color:var(--blue);font-weight:600;text-decoration:none;letter-spacing:.04em;transition:gap .2s;}
  .project-cta:hover{gap:.7rem;color:var(--blue-dark);}
  .project-img-icon{font-size:3rem;opacity:.3;color:#fff;}
  .project-img-label{font-size:.78rem;color:rgba(255,255,255,.5);letter-spacing:.08em;text-transform:uppercase;}
  /* Location */
  .location{background:var(--blue-light);}
  .location-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start;margin-top:3rem;}
  .location-map{aspect-ratio:4/3;background:var(--dark-surface);border:2px solid var(--border);overflow:hidden;border-radius:6px;box-shadow:0 8px 24px rgba(13,71,161,.15);}
  .location-map iframe{width:100%;height:100%;border:none;display:block;}
  .location-points{list-style:none;display:flex;flex-direction:column;gap:1rem;}
  .location-point{display:flex;gap:1rem;align-items:flex-start;padding-bottom:1rem;border-bottom:1px solid rgba(21,101,192,.12);}
  .location-point:last-child{border-bottom:none;}
  .lp-icon{width:38px;height:38px;border-radius:50%;background:var(--blue);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:.9rem;}
  .lp-label{font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);font-weight:600;}
  .lp-value{font-size:.9rem;color:#334;}
  /* Developer */
  .developer{background:#fff;}
  .developer-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;margin-top:3rem;}
  .dev-logo-wrap{background:var(--blue-light);padding:2.5rem;border-radius:8px;display:flex;align-items:center;justify-content:center;border:1px solid rgba(21,101,192,.12);}
  .dev-stats{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;margin-top:2rem;}
  .dev-stat{padding:1.5rem;border:1px solid rgba(21,101,192,.12);background:var(--blue-light);border-radius:4px;}
  .dev-stat-num{font-family:var(--ff-display);font-size:2rem;font-weight:700;color:var(--blue);}
  .dev-stat-label{font-size:.75rem;color:#556;margin-top:.3rem;}
  .developer-content p{color:#445;font-size:.97rem;margin-bottom:1rem;line-height:1.8;}
  /* News */
  .news{background:var(--blue-light);}
  .news-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem;}
  .news-card{background:#fff;border:1px solid rgba(21,101,192,.1);border-radius:6px;overflow:hidden;transition:.3s;display:flex;flex-direction:column;box-shadow:0 2px 8px rgba(13,71,161,.05);}
  .news-card:hover{border-color:var(--blue);transform:translateY(-4px);box-shadow:0 12px 28px rgba(13,71,161,.12);}
  .news-card-img{height:170px;background:linear-gradient(135deg,var(--blue-light),#c8d8f0);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:.5rem;position:relative;overflow:hidden;}
  .news-source-badge{position:absolute;top:.75rem;left:.75rem;background:var(--blue);color:#fff;padding:.2rem .65rem;font-size:.66rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;z-index:2;border-radius:2px;}
  .news-card-body{padding:1.5rem;flex:1;display:flex;flex-direction:column;}
  .news-date{font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);margin-bottom:.5rem;font-weight:600;}
  .news-title{font-family:var(--ff-display);font-size:1.05rem;font-weight:600;line-height:1.4;margin-bottom:.75rem;color:var(--dark-mid);}
  .news-excerpt{font-size:.82rem;color:#556;line-height:1.6;flex:1;}
  .news-link{display:inline-flex;align-items:center;gap:.4rem;margin-top:1rem;font-size:.8rem;color:var(--blue);font-weight:600;text-decoration:none;letter-spacing:.04em;transition:gap .2s;}
  .news-link:hover{gap:.7rem;}
  .news-cta-wrap{margin-top:2.5rem;text-align:center;}
  /* Resale */
  .resale{background:#fff;}
  .resale-intro{max-width:580px;color:#445;font-size:.97rem;margin-bottom:3rem;line-height:1.8;}
  .resale-grid{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start;}
  .resale-info{padding:2rem;border:1px solid rgba(21,101,192,.15);background:var(--blue-light);border-radius:6px;}
  .resale-info h3{font-family:var(--ff-display);font-size:1.4rem;font-weight:700;color:var(--blue-dark);margin-bottom:1rem;}
  .resale-info p{font-size:.87rem;color:#445;margin-bottom:.8rem;line-height:1.7;}
  .resale-steps{list-style:none;margin-top:1.5rem;display:flex;flex-direction:column;gap:.8rem;}
  .resale-steps li{display:flex;gap:.75rem;align-items:flex-start;font-size:.87rem;color:#445;}
  .rs-num{width:24px;height:24px;border-radius:50%;background:var(--blue);color:#fff;font-size:.73rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:.1rem;}
  .form-group{display:flex;flex-direction:column;gap:.4rem;}
  .form-group label{font-size:.73rem;letter-spacing:.08em;text-transform:uppercase;color:#556;font-weight:600;}
  .form-group input,.form-group select,.form-group textarea{background:#fff;border:1.5px solid rgba(21,101,192,.2);color:#334;padding:.85rem 1rem;font-family:var(--ff-body);font-size:.92rem;outline:none;transition:border-color .2s;width:100%;-webkit-appearance:none;border-radius:3px;}
  .form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(21,101,192,.08);}
  .form-group textarea{resize:vertical;min-height:90px;}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
  .file-upload-area{border:2px dashed rgba(21,101,192,.25);background:#f8fbff;padding:1.5rem;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.5rem;cursor:pointer;transition:.2s;text-align:center;border-radius:4px;}
  .file-upload-area:hover{border-color:var(--blue);background:var(--blue-light);}
  .file-upload-area input[type="file"]{display:none;}
  .file-upload-icon{font-size:1.8rem;opacity:.5;}
  .file-upload-text{font-size:.84rem;color:#556;}
  .file-upload-hint{font-size:.73rem;color:#778;}
  .file-name-display{font-size:.78rem;color:var(--blue);margin-top:.3rem;word-break:break-all;font-weight:600;}
  .form-submit{background:var(--blue);color:#fff;border:none;padding:1rem;font-family:var(--ff-body);font-size:.92rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;transition:.2s;margin-top:.5rem;width:100%;border-radius:3px;}
  .form-submit:hover{background:var(--blue-dark);}
  .form-note{font-size:.76rem;color:#778;margin-top:.5rem;text-align:center;}
  .resale-form-wrap{display:flex;flex-direction:column;gap:1rem;}
  .contact{background:var(--blue-light);}
  .contact-wrap{display:grid;grid-template-columns:1fr 1fr;gap:5rem;margin-top:3rem;}
  .contact-detail{display:flex;gap:1rem;align-items:flex-start;margin-bottom:1.5rem;}
  .cd-icon{width:40px;height:40px;border-radius:50%;background:var(--blue);color:#fff;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
  .cd-label{font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);font-weight:600;}
  .cd-value{font-size:.97rem;color:#334;margin-top:.2rem;}
  footer{background:var(--dark-mid);padding:4rem 4rem 2rem;border-top:3px solid var(--blue);}
  .footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:3rem;margin-bottom:3rem;}
  .footer-logo-img{height:44px;width:auto;margin-bottom:1rem;filter:brightness(0) invert(1);opacity:.85;}
  .footer-desc{font-size:.85rem;color:rgba(255,255,255,.55);line-height:1.8;}
  .footer-col h4{font-size:.74rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:1.2rem;}
  .footer-links{list-style:none;display:flex;flex-direction:column;gap:.6rem;}
  .footer-links a{color:rgba(255,255,255,.6);text-decoration:none;font-size:.86rem;transition:color .2s;}
  .footer-links a:hover{color:var(--gold);}
  .footer-bottom{border-top:1px solid rgba(255,255,255,.1);padding-top:1.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;}
  .footer-bottom p{font-size:.78rem;color:rgba(255,255,255,.4);}
  .footer-disclaimer{font-size:.72rem;color:rgba(255,255,255,.3);margin-top:1rem;line-height:1.6;max-width:700px;}
  .sticky-cta{position:fixed;bottom:2rem;right:2rem;z-index:99;display:flex;flex-direction:column;gap:.6rem;}
  .sticky-btn{color:#fff;border:none;padding:.8rem 1.4rem;font-family:var(--ff-body);font-size:.8rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;cursor:pointer;display:flex;align-items:center;gap:.5rem;box-shadow:0 4px 20px rgba(0,0,0,.3);transition:.2s;text-decoration:none;border-radius:3px;background:var(--blue);}
  .sticky-btn:hover{background:var(--blue-dark);transform:translateY(-2px);}
  .sticky-btn.whatsapp{background:#25d366;}
  .sticky-btn.whatsapp:hover{background:#1ebe5a;}
  .fade-up{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease;}
  .fade-up.visible{opacity:1;transform:translateY(0);}
  .lightbox{position:fixed;inset:0;background:rgba(10,22,40,.95);z-index:999;display:none;align-items:center;justify-content:center;padding:2rem;}
  .lightbox.open{display:flex;}
  .lightbox-inner{max-width:800px;width:100%;background:#fff;border-radius:8px;overflow:hidden;position:relative;}
  .lightbox-img-area{height:400px;background:linear-gradient(135deg,var(--blue-light),#c0d8f0);display:flex;align-items:center;justify-content:center;}
  .lightbox-body{padding:2rem;}
  .lightbox-close{position:absolute;top:1rem;right:1rem;background:var(--blue);color:#fff;border:none;width:36px;height:36px;border-radius:50%;font-size:1.1rem;cursor:pointer;display:flex;align-items:center;justify-content:center;}
  @media(max-width:1100px){.amenities-grid{grid-template-columns:repeat(4,1fr);}}
  @media(max-width:900px){
    nav{padding:.7rem 1.2rem;}
    .nav-links,.nav-cta{display:none;}
    .hamburger{display:flex;}
    section{padding:4rem 1.5rem;}
    .hero{padding:0 1.5rem 4rem;}
    .hero h1{font-size:2.2rem;}
    .hero-stats{gap:1.5rem;}
    .about-grid,.location-grid,.developer-grid,.contact-wrap,.resale-grid{grid-template-columns:1fr;gap:2.5rem;}
    .highlights{padding:2rem 1.5rem;}
    .highlights-grid{grid-template-columns:repeat(2,1fr);}
    .amenities-grid{grid-template-columns:repeat(3,1fr);}
    .news-grid,.projects-grid{grid-template-columns:1fr;}
    .gallery-grid{grid-template-columns:1fr 1fr;}
    .cert-grid{grid-template-columns:repeat(2,1fr);}
    .footer-grid{grid-template-columns:1fr 1fr;gap:2rem;}
    .footer-grid>div:first-child{grid-column:1 / -1;}
    .form-row{grid-template-columns:1fr;}
    .scroll-indicator{display:none;}
    .sticky-cta{bottom:1rem;right:1rem;}
    .highlight-item{border-right:none;border-bottom:1px solid rgba(255,255,255,.12);padding-bottom:1rem;}
  }
  @media(max-width:600px){
    .amenities-grid{grid-template-columns:repeat(2,1fr);}
    .gallery-grid{grid-template-columns:1fr;}
    .cert-grid{grid-template-columns:1fr 1fr;}
  }
  body.nav-open .nav-links{display:flex;flex-direction:column;position:fixed;top:62px;left:0;right:0;background:#fff;padding:1.5rem;gap:1rem;border-bottom:3px solid var(--blue);z-index:199;box-shadow:0 8px 24px rgba(0,0,0,.1);}
  body.nav-open .nav-links a{font-size:1rem;padding:.5rem 0;border-bottom:1px solid rgba(21,101,192,.1);}
</style>
</head>
<body>

<!-- NAV -->
<nav id="mainNav">
  <a class="nav-logo-wrap" href="#">

<!-- GALLERY -->
<section class="gallery" id="gallery">
  <div class="section-label">Gallery</div>
  <h2 class="section-title">Project <em>Showcase</em> &amp; Milestones</h2>
  <div class="divider"></div>
  <div class="gallery-tabs">
    <button class="gallery-tab active" onclick="switchTab('ongoing')">🏗️ Ongoing Work</button>
    <button class="gallery-tab" onclick="switchTab('certificates')">🏆 Certificates &amp; Awards</button>
    <button class="gallery-tab" onclick="switchTab('renders')">🖼️ Project Renders</button>
  </div>
  <div class="gallery-panel active fade-up" id="tab-ongoing">
    <div class="gallery-grid">
      <div class="gallery-item" style="background:linear-gradient(135deg,#1a3a6a,#2a5ea0);" onclick="openLightbox('Foundation Work — Phase 1','Site levelling and foundation laying in progress. Area: Sector A, Block 1–4.')">
        <div class="gallery-item-inner"><div class="gallery-item-icon">🏗️</div><div class="gallery-item-label">Foundation Work</div></div>
        <span class="work-status status-active">● Active</span><div class="gallery-item-overlay"></div><div class="gallery-item-caption">Foundation Work — Phase 1</div>
      </div>
      <div class="gallery-item" style="background:linear-gradient(135deg,#2a4a7a,#3a6eae);" onclick="openLightbox('Road Infrastructure','Internal road construction — 24-metre wide roads being laid.')">
        <div class="gallery-item-inner"><div class="gallery-item-icon">🛣️</div><div class="gallery-item-label">Road Construction</div></div>
        <span class="work-status status-active">● Active</span><div class="gallery-item-overlay"></div><div class="gallery-item-caption">Road Infrastructure · Sector B</div>
      </div>
      <div class="gallery-item" style="background:linear-gradient(135deg,#1a4560,#2a6888);" onclick="openLightbox('Drainage & Utilities','Underground drainage and electrical duct laying in progress.')">
        <div class="gallery-item-inner"><div class="gallery-item-icon">⚙️</div><div class="gallery-item-label">Drainage &amp; Utilities</div></div>
        <span class="work-status status-complete">✔ Complete</span><div class="gallery-item-overlay"></div><div class="gallery-item-caption">Drainage &amp; Utilities · Phase 1</div>
      </div>
      <div class="gallery-item" style="background:linear-gradient(135deg,#2a3a6a,#4a5a9a);" onclick="openLightbox('Landscaping','Central park area landscaping and green-belt development.')">
        <div class="gallery-item-inner"><div class="gallery-item-icon">🌿</div><div class="gallery-item-label">Landscaping</div></div>
        <span class="work-status status-active">● Active</span><div class="gallery-item-overlay"></div><div class="gallery-item-caption">Central Park — Landscaping</div>
      </div>
      <div class="gallery-item" style="background:linear-gradient(135deg,#2a4a5a,#1a6a7a);" onclick="openLightbox('Boundary Wall','Perimeter compound wall and gated entry construction.')">
        <div class="gallery-item-inner"><div class="gallery-item-icon">🧱</div><div class="gallery-item-label">Boundary Wall</div></div>
        <span class="work-status status-complete">✔ Complete</span><div class="gallery-item-overlay"></div><div class="gallery-item-caption">Boundary Wall — All Sectors</div>

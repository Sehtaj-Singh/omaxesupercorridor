  <button class="hamburger" onclick="document.body.classList.toggle('nav-open')">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- HERO -->
<section class="hero" id="home">
  <div class="hero-bg-pattern"></div>
  <div class="hero-accent"></div>
  <div class="hero-badge" data-i18n="hero_badge">Pre-launch · RERA Applied · Super Corridor, Indore</div>
  <h1 data-i18n="hero_h1">Madhya Pradesh's <em>first</em><br/>integrated township</h1>
  <p class="hero-sub" data-i18n="hero_sub">A 450-acre integrated township on Indore's fastest-growing Super Corridor — blending premium residential plots, world-class amenities, and long-term investment value.</p>
  <div class="hero-actions">
    <a href="#contact" class="btn-primary" data-i18n="hero_cta1">Book a Site Visit</a>
    <a href="#about" class="btn-outline" data-i18n="hero_cta2">Explore Plots</a>
  </div>
  <div class="hero-stats">
    <div><div class="hero-stat-num">450</div><div class="hero-stat-label" data-i18n="stat1">Acres of Township</div></div>
    <div><div class="hero-stat-num">Dec 2030</div><div class="hero-stat-label" data-i18n="stat4">Expected Possession</div></div>
  </div>
  <div class="scroll-indicator"><div class="scroll-line"></div>Scroll</div>
</section>

<!-- HIGHLIGHTS -->
<div class="highlights">
  <div class="highlights-grid">
    <div class="highlight-item"><div class="highlight-num">₹1,200 Cr</div><div class="highlight-label" data-i18n="hl1">Project Investment</div></div>
    <div class="highlight-item"><div class="highlight-num">119M+</div><div class="highlight-label" data-i18n="hl2">Sq Ft Delivered by Omaxe</div></div>
    <div class="highlight-item"><div class="highlight-num">27</div><div class="highlight-label" data-i18n="hl3">Cities Pan-India</div></div>

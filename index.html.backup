<!-- RESALE -->
<section class="resale section-light" id="resale">
  <div class="section-label" data-i18n="resale_label">Resale Listings</div>
  <h2 class="section-title" data-i18n="resale_title">List Your Plot for <em>Resale</em></h2>
  <div class="divider"></div>
  <p class="resale-intro" data-i18n="resale_intro">Already own a plot in Omaxe Super Corridor? List it with us and reach thousands of genuine buyers.</p>
  <div class="resale-grid">
    <div class="resale-info fade-up">
      <h3 data-i18n="resale_how_title">How Resale Works</h3>
      <p data-i18n="resale_how_p">Submit your listing details and property documents. Our advisor team will verify, list your property, and connect you with qualified buyers.</p>
      <ul class="resale-steps">
        <li><div class="rs-num">1</div><span data-i18n="rs1">Fill the resale form with your contact info and property details.</span></li>
        <li><div class="rs-num">2</div><span data-i18n="rs2">Upload your property documents (sale deed, plot papers, NOC, etc.).</span></li>
        <li><div class="rs-num">3</div><span data-i18n="rs3">Our team reviews and contacts you within 48 hours.</span></li>
        <li><div class="rs-num">4</div><span data-i18n="rs4">Your listing goes live and is shared with active buyers.</span></li>
      </ul>
      <div style="margin-top:2rem;padding:1.25rem;background:#fff;border:1px solid rgba(21,101,192,.15);border-radius:4px;">
        <div style="font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);font-weight:700;margin-bottom:.5rem" data-i18n="resale_note_label">Note</div>
        <div style="font-size:.83rem;color:#445" data-i18n="resale_note">All property documents are reviewed in strict confidence. Listing is free for registered plot owners.</div>
      </div>
    </div>
    <div class="fade-up">
      <form class="resale-form-wrap" onsubmit="handleResaleSubmit(event)">
        <div class="form-row">
          <div class="form-group"><label for="r_fname" data-i18n="r_fname">First Name</label><input type="text" id="r_fname" placeholder="Rahul" required/></div>
          <div class="form-group"><label for="r_lname" data-i18n="r_lname">Last Name</label><input type="text" id="r_lname" placeholder="Sharma" required/></div>
        </div>
        <div class="form-group"><label for="r_phone" data-i18n="r_phone">Contact Number</label><input type="tel" id="r_phone" placeholder="+91 98XXX XXXXX" required/></div>
        <div class="form-group"><label for="r_email" data-i18n="r_email">Email Address</label><input type="email" id="r_email" placeholder="rahul@email.com"/></div>
        <div style="font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--blue);font-weight:700;margin:.4rem 0 -.2rem" data-i18n="r_property_section">Property Details</div>
        <div class="form-group"><label for="r_plotno" data-i18n="r_plotno">Plot Number / Block</label><input type="text" id="r_plotno" placeholder="e.g. A-42, Block 3"/></div>
        <div class="form-row">
          <div class="form-group"><label for="r_plotsize" data-i18n="r_plotsize">Plot Size (sq ft)</label><input type="text" id="r_plotsize" placeholder="e.g. 1200"/></div>
          <div class="form-group"><label for="r_askprice" data-i18n="r_askprice">Asking Price (₹)</label><input type="text" id="r_askprice" placeholder="e.g. 45,00,000"/></div>
        </div>
        <div class="form-group"><label for="r_details" data-i18n="r_details">Additional Details</label><textarea id="r_details" placeholder="Corner plot, east-facing, near park..."></textarea></div>
        <div class="form-group">
          <label data-i18n="r_docs">Property Documents (PDF / JPG / PNG)</label>
          <div class="file-upload-area" onclick="document.getElementById('r_files').click()">
            <input type="file" id="r_files" accept=".pdf,.jpg,.jpeg,.png" multiple onchange="showFileNames(this)"/>
            <div class="file-upload-icon">📎</div>
            <div class="file-upload-text" data-i18n="r_upload_text">Click to upload documents</div>
            <div class="file-upload-hint" data-i18n="r_upload_hint">Sale deed, plot papers, NOC, Aadhar — max 10MB each</div>
            <div class="file-name-display" id="fileNameDisplay"></div>
          </div>
        </div>
        <button type="submit" class="form-submit" data-i18n="r_submit">Submit Resale Listing →</button>
        <p class="form-note" data-i18n="r_note">Documents handled with full confidentiality. Team contacts you within 48 hours.</p>
      </form>
    </div>
  </div>
</section>

<!-- CONTACT -->
<section class="contact" id="contact">
  <div class="section-label" data-i18n="contact_label">Get In Touch</div>
  <h2 class="section-title" data-i18n="contact_title">Take the First Step to Your <em>Dream</em> Home</h2>
  <div class="divider"></div>
  <div class="contact-wrap">
    <div class="fade-up">
      <p style="color:#445;font-size:.97rem;margin-bottom:2rem;line-height:1.8;" data-i18n="contact_p">Our advisors are ready to answer your queries about plots, pricing, payment plans, and site visits.</p>
      <div class="contact-detail"><div class="cd-icon">📞</div><div><div class="cd-label" data-i18n="cd1l">Phone / WhatsApp</div><div class="cd-value">+91 XXXXX XXXXX</div></div></div>
      <div class="contact-detail"><div class="cd-icon">📧</div><div><div class="cd-label" data-i18n="cd2l">Email</div><div class="cd-value">info@omaxesupercorridor.com</div></div></div>
      <div class="contact-detail"><div class="cd-icon">📍</div><div><div class="cd-label" data-i18n="cd3l">Site Location</div><div class="cd-value" data-i18n="cd3v">Super Corridor, Indore, Madhya Pradesh</div></div></div>
      <div class="contact-detail"><div class="cd-icon">🕐</div><div><div class="cd-label" data-i18n="cd4l">Office Hours</div><div class="cd-value" data-i18n="cd4v">Mon – Sat, 10:00 AM – 7:00 PM</div></div></div>
    </div>
    <div class="fade-up">
      <form class="resale-form-wrap" onsubmit="handleEnquirySubmit(event)" style="background:#fff;padding:2rem;border-radius:6px;box-shadow:0 4px 20px rgba(13,71,161,.08);">
        <div class="form-row">
          <div class="form-group"><label for="e_fname" data-i18n="r_fname">First Name</label><input type="text" id="e_fname" placeholder="Rahul" required/></div>
          <div class="form-group"><label for="e_lname" data-i18n="r_lname">Last Name</label><input type="text" id="e_lname" placeholder="Sharma" required/></div>
        </div>
        <div class="form-group"><label for="e_phone" data-i18n="r_phone">Mobile Number</label><input type="tel" id="e_phone" placeholder="+91 98XXX XXXXX" required/></div>
        <div class="form-group"><label for="e_email" data-i18n="r_email">Email Address</label><input type="email" id="e_email" placeholder="rahul@email.com"/></div>
        <div class="form-group">
          <label for="e_size" data-i18n="e_size">Interested Plot Size</label>
          <select id="e_size"><option value="" data-i18n="e_size_opt0">Select a size</option><option>800 – 1,000 sq ft</option><option>1,000 – 2,000 sq ft</option><option>2,000 – 5,000 sq ft</option><option data-i18n="e_size_opt4">Not decided yet</option></select>
        </div>
        <div class="form-group"><label for="e_msg" data-i18n="e_msg">Message (Optional)</label><textarea id="e_msg" placeholder="Any questions or specific requirements..."></textarea></div>
        <button type="submit" class="form-submit" data-i18n="e_submit">Send Enquiry →</button>
        <p class="form-note" data-i18n="form_conf">Your details are kept strictly confidential. No spam, ever.</p>
      </form>
    </div>
  </div>
</section>


        <div style="background:var(--red);border-radius:1px;display:flex;align-items:center;justify-content:center;"><div style="width:6px;height:6px;background:#fff;border-radius:50%;"></div></div>
        <div style="background:var(--red);border-radius:1px;"></div>
        <div style="background:var(--red);border-radius:1px;"></div>
      </div>
